<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/img_widget_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/widget_main_background"
        android:scaleType="fitXY" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Row 1: Dates -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:paddingHorizontal="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/icon_star"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="@string/widget_moon_phase_icon_desc"
                    android:src="@android:drawable/star_on"
                    android:tint="#FFFFFF" />

                <TextView
                    android:id="@+id/text_gregorian_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fri, 5 June"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <TextView
                android:id="@+id/text_hijri_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="19 Dhul-Hijjah"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium" />
        </RelativeLayout>

        <!-- Row 2: Location and Countdown -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:paddingHorizontal="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/icon_location"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="@string/widget_map_pin_icon_desc"
                    android:src="@android:drawable/ic_menu_mylocation"
                    android:tint="#99FFFFFF" />

                <TextView
                    android:id="@+id/text_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Düsseldorf"
                    android:textColor="#99FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>

            <Chronometer
                android:id="@+id/text_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:textColor="#99FFFFFF"
                android:textSize="12sp"
                android:countDown="true" />
        </RelativeLayout>

        <!-- Row 3: Prayer Times Panel (6 Slots) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/img_panel_bg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/widget_inner_panel"
                android:scaleType="fitXY" />

            <LinearLayout
                android:id="@+id/panel_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp"
                android:weightSum="6">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/label_fajr" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fajr" android:textColor="#B3FFFFFF" android:textSize="10sp" android:textStyle="bold" />
                    <TextView android:id="@+id/time_fajr" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="03:48" android:textColor="#FFFFFF" android:textSize="10sp" android:layout_marginTop="2dp" android:paddingHorizontal="4dp" android:paddingVertical="2dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/label_shuruq" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Shuruq" android:textColor="#B3FFFFFF" android:textSize="10sp" />
                    <TextView android:id="@+id/time_shuruq" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="05:20" android:textColor="#B3FFFFFF" android:textSize="10sp" android:layout_marginTop="2dp" android:paddingHorizontal="4dp" android:paddingVertical="2dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/label_dhuhr" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dhuhr" android:textColor="#B3FFFFFF" android:textSize="10sp" />
                    <TextView android:id="@+id/time_dhuhr" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="13:31" android:textColor="#B3FFFFFF" android:textSize="10sp" android:layout_marginTop="2dp" android:paddingHorizontal="4dp" android:paddingVertical="2dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/label_asr" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Asr" android:textColor="#B3FFFFFF" android:textSize="10sp" />
                    <TextView android:id="@+id/time_asr" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="17:52" android:textColor="#B3FFFFFF" android:textSize="10sp" android:layout_marginTop="2dp" android:paddingHorizontal="4dp" android:paddingVertical="2dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/label_maghrib" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Maghrib" android:textColor="#B3FFFFFF" android:textSize="10sp" />
                    <TextView android:id="@+id/time_maghrib" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="21:43" android:textColor="#B3FFFFFF" android:textSize="10sp" android:layout_marginTop="2dp" android:paddingHorizontal="4dp" android:paddingVertical="2dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/label_isha" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Isha" android:textColor="#B3FFFFFF" android:textSize="10sp" />
                    <TextView android:id="@+id/time_isha" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="23:14" android:textColor="#B3FFFFFF" android:textSize="10sp" android:layout_marginTop="2dp" android:paddingHorizontal="4dp" android:paddingVertical="2dp"/>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
